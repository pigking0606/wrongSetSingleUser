# 设置 DashScope API Key 启用真实 AI 分析（千问 Qwen-VL）
# 不设置则使用 Mock 模式（返回模拟数据，用于开发调试）
# API Key 获取地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# AI 模型选择（可选，默认 qwen-vl-plus）
# qwen-vl-plus : 性价比首选，OCR+分类+解析，1.5/4.5 元/百万token（推荐）
# qwen-vl-max  : 旗舰版，能力最强，3/9 元/百万token
# qwen-vl-ocr  : 纯OCR专用，最便宜 0.3/0.5 元/百万token（仅识别文字，不解析）
DASHSCOPE_MODEL=qwen-vl-plus
